+		pinctrl-names = "default";
+		pinctrl-0 = <&nfc_default>;
+	};
+};
+
+&i2c5 {
+	#dma-cells = <3>;
+	clock-frequency = <400000>;
+
+	dmas =  <&gpi_dma0 0 5 QCOM_GPI_I2C>,
+			<&gpi_dma0 1 5 QCOM_GPI_I2C>;
+	dma-names = "tx", "rx";
+
+	status = "okay";
+
+	tas2557_codec: tas2557@4c{
+		#sound-dai-cells = <1>;
+		compatible = "ti,tas2557";
+		reg = <0x4c>;
+		ti,cdc-reset-gpio = <&tlmm 69 0>;
+		ti,irq-gpio = <&tlmm 30 0>;
+		ti,bypass-tmax = <0>;
+	};
+};
+
+&i2c14 {
+	#dma-cells = <3>;
+	clock-frequency = <400000>;
+
+	dmas =  <&gpi_dma1 0 6 QCOM_GPI_I2C>,
+		<&gpi_dma1 1 6 QCOM_GPI_I2C>;
+	dma-names = "tx", "rx";
+
+	status = "okay";
+
+	touchscreen@49 {
+		compatible = "st,stmfts5", "st,stmfts", "st,fts";
+		reg = <0x49>;
+		interrupts-extended = <&tlmm 31 IRQ_TYPE_LEVEL_LOW>;
+
+		pinctrl-0 = <&ts_int_default &ts_reset_default>;
+		pinctrl-1 = <&ts_int_sleep &ts_reset_sleep>;
+		pinctrl-names = "default", "sleep";
+
+		vdd-supply = <&disp_vddio_vreg>;
+		avdd-supply = <&vreg_l28a_3p0>;
+		vcc-supply = <&lab>;
+
+		touchscreen-size-x = <1079>;
+		touchscreen-size-y = <2339>;
+
+		/* downstream driver */
+		st,pwr-reg-name = "avdd";
+		st,bus-reg-name = "vdd";
+		st,irq-gpio = <&tlmm 31 0x2008>;
+		st,reset-gpio = <&tlmm 32 0x00>;
+		st,max-coords = <1079 2339>;
+		st,config-array-size = <1>;
+		st,default-fw-name = "st_fts_e5.ftb";
+		st,cfg_0 {
+			st,fw-name = "st_fts_e5.ftb";
+			st,limit-name = "stm_fts_production_limits.csv";
+		};
+	};
+};
