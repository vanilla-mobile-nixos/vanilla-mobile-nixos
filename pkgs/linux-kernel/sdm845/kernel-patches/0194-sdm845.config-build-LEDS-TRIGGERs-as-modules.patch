From 8f09a750f2cf8cf978a085bb6747f0061fca7572 Mon Sep 17 00:00:00 2001
From: Joel Selvaraj <foss@joelselvaraj.com>
Date: Fri, 1 May 2026 01:10:40 -0500
Subject: [PATCH 194/194] sdm845.config: build LEDS TRIGGERs as modules

Tested in op6. Both notification led and flash led works as expected.

Signed-off-by: Joel Selvaraj <foss@joelselvaraj.com>
---
 arch/arm64/configs/sdm845.config | 19 +++++++------------
 1 file changed, 7 insertions(+), 12 deletions(-)

diff --git a/arch/arm64/configs/sdm845.config b/arch/arm64/configs/sdm845.config
index fd80a973ccf8..b7a118f3911d 100644
--- a/arch/arm64/configs/sdm845.config
+++ b/arch/arm64/configs/sdm845.config
@@ -99,21 +99,16 @@ CONFIG_SCSI_UFS_BSG=y
 CONFIG_PHY_QCOM_QMP_PCIE=y
 CONFIG_BACKLIGHT_CLASS_DEVICE=y
 CONFIG_INTERCONNECT_QCOM_OSM_L3=y
-
-# Notification LED
-# Must be builtin as it won't be automatically modprobed
-# but pmos requires it to be a module. for testing, building
-# it as a module. Trying making it built-in if issue occurs.
-CONFIG_LEDS_TRIGGER_PATTERN=m
-CONFIG_LEDS_CLASS_MULTICOLOR=m
-CONFIG_LEDS_QCOM_LPG=m
 CONFIG_I2C_QCOM_GENI=y
 
-# Flash LED
+# Notification and Flash LED
+CONFIG_LEDS_QCOM_LPG=m
 CONFIG_LEDS_QCOM_FLASH=m
-CONFIG_LEDS_TRIGGER_ONESHOT=y
-CONFIG_LEDS_TRIGGER_BACKLIGHT=y
-CONFIG_LEDS_TRIGGER_ACTIVITY=y
+CONFIG_LEDS_CLASS_MULTICOLOR=m
+CONFIG_LEDS_TRIGGER_PATTERN=m
+CONFIG_LEDS_TRIGGER_ONESHOT=m
+CONFIG_LEDS_TRIGGER_BACKLIGHT=m
+CONFIG_LEDS_TRIGGER_ACTIVITY=m
 CONFIG_LEDS_TRIGGER_TIMER=m
 
 # Touchscreen - Pocophone F1 / SHIFT6mq
-- 
2.53.0

