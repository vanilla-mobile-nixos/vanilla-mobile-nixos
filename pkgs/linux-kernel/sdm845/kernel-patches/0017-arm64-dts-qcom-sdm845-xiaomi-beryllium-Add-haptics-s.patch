From a1e067e88de226e0e1093201e50f1d0f68a201dc Mon Sep 17 00:00:00 2001
From: Joel Selvaraj <jo@jsfamily.in>
Date: Thu, 17 Jun 2021 07:43:30 +0530
Subject: [PATCH 017/194] arm64: dts: qcom: sdm845-xiaomi-beryllium: Add
 haptics support

Enable the pmi8998 SPMI haptics driver and configure the play rate for the
hardware.

[David] properties sort
Signed-off-by: Joel Selvaraj <jo@jsfamily.in>
Signed-off-by: Casey Connolly <casey@connolly.tech>
Signed-off-by: David Heidelberg <david@ixit.cz>
---
 .../arm64/boot/dts/qcom/sdm845-xiaomi-beryllium-common.dtsi | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sdm845-xiaomi-beryllium-common.dtsi b/arch/arm64/boot/dts/qcom/sdm845-xiaomi-beryllium-common.dtsi
index 950bbcc3bf91..01e753382440 100644
--- a/arch/arm64/boot/dts/qcom/sdm845-xiaomi-beryllium-common.dtsi
+++ b/arch/arm64/boot/dts/qcom/sdm845-xiaomi-beryllium-common.dtsi
@@ -394,6 +394,12 @@
 	};
 };
 
+&pmi8998_haptics {
+	qcom,wave-play-rate-us = <4878>;
+
+	status = "okay";
+};
+
 &pm8998_resin {
 	linux,code = <KEY_VOLUMEDOWN>;
 	status = "okay";
-- 
