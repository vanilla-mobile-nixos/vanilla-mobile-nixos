+	struct max98512_priv *max98512 = snd_soc_codec_get_drvdata(codec);
+#endif
+	struct max98512_pdata *pdata = max98512->pdata;
+	int osm = (int)ucontrol->value.integer.value[0];
+
+	osm = osm < 0 ? 0 : osm;
+	if (osm < MAX98512_OSM_MAX && pdata->osm != osm)
+		pdata->osm = osm;
