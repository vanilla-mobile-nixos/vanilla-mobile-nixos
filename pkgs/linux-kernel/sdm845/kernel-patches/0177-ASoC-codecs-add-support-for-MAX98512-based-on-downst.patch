+#define DSM_RX_PORT_ID	0x4000
+#define DSM_TX_PORT_ID	(DSM_RX_PORT_ID + 1)
+
+#define AFE_MODULE_ID_DSM_RX				0x10001062
+#define AFE_MODULE_ID_DSM_TX				0x0FF1020B
+
+#define AFE_PARAM_ID_ENABLE_DSM_RX_ENABLE	0x10001063
