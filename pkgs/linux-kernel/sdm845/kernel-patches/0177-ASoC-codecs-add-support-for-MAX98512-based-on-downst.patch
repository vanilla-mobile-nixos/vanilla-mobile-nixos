+					MAX98512_R003A_SPK_GAIN,
+					MAX98512_SPK_PCM_GAIN_MASK,
+					max98512->spk_gain_right);
+	} else {
+		max98512_wrapper_update(max98512, MAX98512B,
+					MAX98512_R003A_SPK_GAIN,
+					MAX98512_SPK_PCM_GAIN_MASK,
+					0);
