 M:	Avoid Warnings <dev@null.cz>
 S:	Unmaintained
+F:	sound/soc/qcom/qdsp6/q6cvs.c
 F:	sound/soc/qcom/qdsp6/q6cvp.c
 F:	sound/soc/qcom/qdsp6/q6mvm.c
 F:	sound/soc/qcom/qdsp6/q6voice-common.c
diff --git a/sound/soc/qcom/qdsp6/Makefile b/sound/soc/qcom/qdsp6/Makefile
index 07bac415f0d3..4856fc094f30 100644
--- a/sound/soc/qcom/qdsp6/Makefile
+++ b/sound/soc/qcom/qdsp6/Makefile
@@ -11,7 +11,7 @@ obj-$(CONFIG_SND_SOC_QDSP6_ADM) += q6adm.o
 obj-$(CONFIG_SND_SOC_QDSP6_ROUTING) += q6routing.o
 obj-$(CONFIG_SND_SOC_QDSP6_ASM) += q6asm.o
 obj-$(CONFIG_SND_SOC_QDSP6_ASM_DAI) += q6asm-dai.o
-obj-$(CONFIG_SND_SOC_QDSP6_Q6VOICE) += q6cvp.o q6mvm.o q6voice-common.o
