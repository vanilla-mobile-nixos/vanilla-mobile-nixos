@@ -74,6 +74,12 @@ CONFIG_BACKLIGHT_PWM=y
 CONFIG_EC_LENOVO_YOGA_C630=m
 CONFIG_BATTERY_LENOVO_YOGA_C630=m
 
+# LG G7 ThinQ
+CONFIG_DRM_PANEL_LG_SW49410_LH609QH1=y
