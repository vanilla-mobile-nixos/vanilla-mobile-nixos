Date: Mon, 3 Feb 2025 11:50:32 -0500
Subject: [PATCH 077/194] stalled! media: i2c: Add imx519 image sensor driver

[David]
 - rework of imx519 dphy for 6MQ
 - document registers
---
 MAINTAINERS                |    8 +
 drivers/media/i2c/Kconfig  |   14 +
 drivers/media/i2c/Makefile |    1 +
 drivers/media/i2c/imx519.c | 2033 ++++++++++++++++++++++++++++++++++++
 4 files changed, 2056 insertions(+)
 create mode 100644 drivers/media/i2c/imx519.c

diff --git a/MAINTAINERS b/MAINTAINERS
index 7f805048da6d..a045fbe19cbd 100644
--- a/MAINTAINERS
+++ b/MAINTAINERS
@@ -24911,6 +24911,14 @@ T:	git git://linuxtv.org/media.git
 F:	Documentation/devicetree/bindings/media/i2c/sony,imx415.yaml
 F:	drivers/media/i2c/imx415.c
 
+SONY IMX519 SENSOR DRIVER
+M:	Arducam Kernel Maintenance <info@arducam.com>
+M:	Lee Jackson <lee.jackson@arducam.com>
+L:	linux-media@vger.kernel.org
+S:	Maintained
+T:	git git://linuxtv.org/media_tree.git
+F:	Documentation/devicetree/bindings/media/i2c/sony,imx519.yaml
+
 SONY MEMORYSTICK SUBSYSTEM
 M:	Maxim Levitsky <maximlevitsky@gmail.com>
 M:	Alex Dubov <oakad@yahoo.com>
diff --git a/drivers/media/i2c/Kconfig b/drivers/media/i2c/Kconfig
index 25f19bd9968d..a96d659400ba 100644
--- a/drivers/media/i2c/Kconfig
+++ b/drivers/media/i2c/Kconfig
@@ -317,6 +317,20 @@ config VIDEO_IMX415
 	  To compile this driver as a module, choose M here: the
 	  module will be called imx415.
 
+config VIDEO_IMX519
+	tristate "Sony IMX519 sensor support"
+	depends on I2C && VIDEO_DEV
+	select MEDIA_CONTROLLER
+	select VIDEO_V4L2_SUBDEV_API
+	select V4L2_CCI_I2C
+	select V4L2_FWNODE
+	help
+	  This is a Video4Linux2 sensor driver for the Sony
+	  IMX519 camera.
+
+	  To compile this driver as a module, choose M here: the
+	  module will be called imx519.
+
 config VIDEO_MAX9271_LIB
 	tristate
 
diff --git a/drivers/media/i2c/Makefile b/drivers/media/i2c/Makefile
index 7465d75a6572..3429b811d6ec 100644
--- a/drivers/media/i2c/Makefile
+++ b/drivers/media/i2c/Makefile
@@ -64,6 +64,7 @@ obj-$(CONFIG_VIDEO_IMX371) += imx371.o
 obj-$(CONFIG_VIDEO_IMX376) += imx376.o
 obj-$(CONFIG_VIDEO_IMX412) += imx412.o
 obj-$(CONFIG_VIDEO_IMX415) += imx415.o
+obj-$(CONFIG_VIDEO_IMX519) += imx519.o
 obj-$(CONFIG_VIDEO_IR_I2C) += ir-kbd-i2c.o
 obj-$(CONFIG_VIDEO_ISL7998X) += isl7998x.o
 obj-$(CONFIG_VIDEO_KS0127) += ks0127.o
diff --git a/drivers/media/i2c/imx519.c b/drivers/media/i2c/imx519.c
new file mode 100644
index 000000000000..4834d687a4b3
--- /dev/null
+++ b/drivers/media/i2c/imx519.c
@@ -0,0 +1,2033 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * A V4L2 driver for Sony IMX519 cameras.
+ * Copyright (C) 2021 Arducam Technology co., Ltd.
+ *
+ * Based on Sony IMX477 camera driver
+ * Copyright (C) 2020 Raspberry Pi (Trading) Ltd
+ */
+#include <linux/unaligned.h>
+#include <linux/clk.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/i2c.h>
+#include <linux/module.h>
+#include <linux/of_device.h>
+#include <linux/pm_runtime.h>
+#include <linux/regulator/consumer.h>
+#include <media/v4l2-cci.h>
+#include <media/v4l2-ctrls.h>
+#include <media/v4l2-device.h>
+#include <media/v4l2-event.h>
+#include <media/v4l2-fwnode.h>
+#include <media/v4l2-mediabus.h>
+
+/* Chip ID */
+#define IMX519_REG_CHIP_ID		CCI_REG16(0x0016)
+#define IMX519_CHIP_ID			0x0519
+
+/* CCS standard registers */
+#define IMX519_REG_MODE_SELECT		CCI_REG8(0x0100)
+#define IMX519_MODE_STANDBY		0x00
+#define IMX519_MODE_STREAMING		0x01
+
+#define IMX519_REG_ORIENTATION		CCI_REG8(0x0101)
+#define IMX519_REG_FAST_STANDBY_CTRL	CCI_REG8(0x0106)
+#define IMX519_REG_CSI_SIGNALING_MODE	CCI_REG8(0x0111)
+#define IMX519_CSI_SIGNALING_DPHY	0x02
+#define IMX519_CSI_SIGNALING_CPHY	0x03
+#define IMX519_REG_CSI_DATA_FORMAT	CCI_REG16(0x0112)
+#define IMX519_REG_CSI_LANE_MODE	CCI_REG8(0x0114)
+#define IMX519_CSI_3_LANE_MODE		0x02
+#define IMX519_CSI_4_LANE_MODE		0x03
+#define IMX519_REG_EXTCLK_FREQ		CCI_REG16(0x0136)
+
+/* HDR registers */
+#define IMX519_REG_HDR_MODE		CCI_REG8(0x0220)
+#define IMX519_REG_HDR_RESOLUTION	CCI_REG8(0x0221)
+#define IMX519_REG_EXPOSURE_RATIO	CCI_REG8(0x0222)
+
+/* PLL registers */
+#define IMX519_REG_VT_PIX_CLK_DIV	CCI_REG8(0x0301)
+#define IMX519_REG_VT_SYS_CLK_DIV	CCI_REG8(0x0303)
+#define IMX519_REG_PRE_PLL_CLK_DIV	CCI_REG8(0x0305)
+#define IMX519_REG_PLL_MULTIPLIER	CCI_REG16(0x0306)
+#define IMX519_REG_OP_PIX_CLK_DIV	CCI_REG8(0x0309)
+#define IMX519_REG_OP_SYS_CLK_DIV	CCI_REG8(0x030b)
+#define IMX519_REG_OP_PRE_PLL_CLK_DIV	CCI_REG8(0x030d)
+#define IMX519_REG_OP_PLL_MULTIPLIER	CCI_REG16(0x030e)
+#define IMX519_REG_PLL_MODE		CCI_REG8(0x0310)
+#define IMX519_PLL_MODE_DUAL		0x01
+
+/* Frame / line timing */
+#define IMX519_REG_FRAME_LENGTH		CCI_REG16(0x0340)
+#define IMX519_REG_LINE_LENGTH_PCK	CCI_REG16(0x0342)
+
+/* Crop window */
+#define IMX519_REG_X_ADDR_START		CCI_REG16(0x0344)
+#define IMX519_REG_Y_ADDR_START		CCI_REG16(0x0346)
+#define IMX519_REG_X_ADDR_END		CCI_REG16(0x0348)
+#define IMX519_REG_Y_ADDR_END		CCI_REG16(0x034a)
+#define IMX519_REG_X_OUTPUT_SIZE	CCI_REG16(0x034c)
+#define IMX519_REG_Y_OUTPUT_SIZE	CCI_REG16(0x034e)
+
+/* Scaling */
+#define IMX519_REG_SCALING_MODE		CCI_REG8(0x0401)
+#define IMX519_REG_SCALE_M		CCI_REG16(0x0404)
+#define IMX519_REG_DIGITAL_CROP_X_OFFSET CCI_REG16(0x0408)
+#define IMX519_REG_DIGITAL_CROP_Y_OFFSET CCI_REG16(0x040a)
+#define IMX519_REG_DIGITAL_CROP_WIDTH	CCI_REG16(0x040c)
+#define IMX519_REG_DIGITAL_CROP_HEIGHT	CCI_REG16(0x040e)
+
+/* Link bit rate (32-bit, Mbps with 8 fractional bits) */
+#define IMX519_REG_REQUESTED_LINK_RATE	CCI_REG32(0x0820)
+
+/* Shading correction */
+#define IMX519_REG_SHADING_CORRECTION_EN CCI_REG8(0x0b00)
+
+/* Binning */
+#define IMX519_REG_BINNING_MODE		CCI_REG8(0x0900)
+#define IMX519_REG_BINNING_TYPE		CCI_REG8(0x0901)
+#define IMX519_REG_BINNING_WEIGHTING	CCI_REG8(0x0902)
+
+#define IMX519_XCLK_FREQ		24000000
+
+/* D-PHY link frequency: 740 MHz */
+#define IMX519_LINK_FREQ_DPHY		740000000LL
+/* C-PHY link frequency: ~500.4 MHz (symbol rate) */
+#define IMX519_LINK_FREQ_CPHY		500399375LL
+
+/*
+ * Pixel rates reported to userspace.
+ * D-PHY: 4 lanes * 740 MHz * 2 bits/symbol / 10 bpp = 592 Mpix/s
+ * C-PHY: 3 trios * 500.4 MHz * 2.28 bits/symbol * 16/7 / 10 bpp ≈ 1143.77 Mpix/s
+ */
+#define IMX519_PIXEL_RATE_DPHY		592000000LL
+#define IMX519_PIXEL_RATE_CPHY		1143770000LL
+
+/*
+ * Internal total pixel clock used for frame-length timing math.
+ * This is line_length_pix * frame_length_lines * fps for the mode and is
+ * distinct from the V4L2 pixel rate (active data bandwidth on the link).
+ *
+ * D-PHY: 8320 * 4006 * 30 = 999897600
+ * C-PHY: 16896 * 3572 * 10 = 603471120 (full-res 10fps), verified across modes
+ */
+#define IMX519_PIXCLK_DPHY		999897600LL
+#define IMX519_PIXCLK_CPHY		603471120LL
+
+#define IMX519_FRAME_LENGTH_MAX		0xffdc
+
+/* Long exposure multiplier */
+#define IMX519_LONG_EXP_SHIFT_MAX	7
+#define IMX519_LONG_EXP_SHIFT_REG	CCI_REG8(0x3100)
+
+/* Exposure control */
+#define IMX519_REG_EXPOSURE		CCI_REG16(0x0202)
+#define IMX519_EXPOSURE_OFFSET		32
+#define IMX519_EXPOSURE_MIN		20
+#define IMX519_EXPOSURE_STEP		1
+#define IMX519_EXPOSURE_DEFAULT		0x3e8
+#define IMX519_EXPOSURE_MAX		(IMX519_FRAME_LENGTH_MAX - \
+					 IMX519_EXPOSURE_OFFSET)
+
+/* Analog gain control */
+#define IMX519_REG_ANALOG_GAIN		CCI_REG16(0x0204)
+#define IMX519_ANA_GAIN_MIN		0
+#define IMX519_ANA_GAIN_MAX		960
+#define IMX519_ANA_GAIN_STEP		1
+#define IMX519_ANA_GAIN_DEFAULT		0x0
+
+/* Digital gain control */
+#define IMX519_REG_DIGITAL_GAIN		CCI_REG16(0x020e)
+#define IMX519_DGTL_GAIN_MIN		0x0100
+#define IMX519_DGTL_GAIN_MAX		0xffff
+#define IMX519_DGTL_GAIN_DEFAULT	0x0100
+#define IMX519_DGTL_GAIN_STEP		1
+
+/* Test Pattern Control */
+#define IMX519_REG_TEST_PATTERN		CCI_REG16(0x0600)
+#define IMX519_TEST_PATTERN_DISABLE	0
+#define IMX519_TEST_PATTERN_SOLID_COLOR	1
+#define IMX519_TEST_PATTERN_COLOR_BARS	2
+#define IMX519_TEST_PATTERN_GREY_COLOR	3
+#define IMX519_TEST_PATTERN_PN9		4
+
+/* Test pattern colour components */
+#define IMX519_REG_TEST_PATTERN_R	CCI_REG16(0x0602)
+#define IMX519_REG_TEST_PATTERN_GR	CCI_REG16(0x0604)
+#define IMX519_REG_TEST_PATTERN_B	CCI_REG16(0x0606)
+#define IMX519_REG_TEST_PATTERN_GB	CCI_REG16(0x0608)
+#define IMX519_TEST_PATTERN_COLOUR_MIN	0
+#define IMX519_TEST_PATTERN_COLOUR_MAX	0x0fff
+#define IMX519_TEST_PATTERN_COLOUR_STEP	1
+#define IMX519_TEST_PATTERN_R_DEFAULT	IMX519_TEST_PATTERN_COLOUR_MAX
+#define IMX519_TEST_PATTERN_GR_DEFAULT	0
+#define IMX519_TEST_PATTERN_B_DEFAULT	0
+#define IMX519_TEST_PATTERN_GB_DEFAULT	0
+
+/* Embedded metadata stream structure */
+#define IMX519_EMBEDDED_LINE_WIDTH (5820 * 3)
+#define IMX519_NUM_EMBEDDED_LINES 1
+
+enum pad_types {
+	IMAGE_PAD,
+	METADATA_PAD,
+	NUM_PADS
+};
+
+/* IMX519 native and active pixel array size. */
+#define IMX519_NATIVE_WIDTH		4672U
+#define IMX519_NATIVE_HEIGHT		3648U
+#define IMX519_PIXEL_ARRAY_LEFT		8U
+#define IMX519_PIXEL_ARRAY_TOP		48U
+#define IMX519_PIXEL_ARRAY_WIDTH	4656U
+#define IMX519_PIXEL_ARRAY_HEIGHT	3496U
+
+struct imx519_reg_list {
+	unsigned int num_of_regs;
+	const struct cci_reg_sequence *regs;
+};
+
+/* Mode : resolution and related config&values */
+struct imx519_mode {
+	unsigned int width;
+	unsigned int height;
+	unsigned int line_length_pix;
+	struct v4l2_rect crop;
+	struct v4l2_fract timeperframe_min;
+	struct v4l2_fract timeperframe_default;
+	struct imx519_reg_list reg_list;
+};
+
+/* PHY-specific configuration (link rate, PLL, signaling) */
+struct imx519_phy_config {
+	u32 bus_type;
+	s64 link_freq;
+	s64 pixel_rate;
+	s64 pixclk_hz;
+	unsigned int num_lanes;
+	struct imx519_reg_list phy_regs;
+	const struct imx519_mode *modes;
+	unsigned int num_modes;
+};
+
