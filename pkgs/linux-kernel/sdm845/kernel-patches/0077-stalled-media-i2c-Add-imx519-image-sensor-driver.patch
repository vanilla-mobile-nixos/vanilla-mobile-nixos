+static const char * const imx519_supply_name[] = {
+	/* Supplies can be enabled in any order */
+	"vana",		/* Analog (2.8V) supply */
+	"vcore",	/* Digital Core (1.05V) supply */
+	"vio",		/* IF (1.8V) supply */
+};
