 sound/soc/codecs/Makefile  |    4 +
 sound/soc/codecs/tas2557.c | 1957 ++++++++++++++++++++++++++++++++++++
 sound/soc/codecs/tas2557.h |  377 +++++++
 4 files changed, 2344 insertions(+)
 create mode 100644 sound/soc/codecs/tas2557.c
