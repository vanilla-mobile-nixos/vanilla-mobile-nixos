+	struct snd_pcm_hw_params *pParams, struct snd_soc_dai *pDAI)
+{
+	struct snd_soc_component *pCodec = pDAI->component;
+	struct tas2557_priv *pTAS2557 = snd_soc_component_get_drvdata(pCodec);
